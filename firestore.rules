rules_version = '2';

// このルールはデプロイ用ではなく、Firestore エミュレータを起動して
// 「Firestore → Neon 移行スクリプト」をテストするためだけに存在する。
// 移行は firebase-admin（管理者権限）で実行するためルールはバイパスされる。
// 本番の Firestore はこの移行をもって廃止する。
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
