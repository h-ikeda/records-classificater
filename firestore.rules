rules_version = '2';
// Emulator-only rules. The migration runs through the Firebase Admin SDK, which
// bypasses rules entirely; these exist only so the Firestore emulator has a
// rules file to load. They are NOT deployed anywhere.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
