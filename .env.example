# 本番 / プレビューでは Neon・Clerk の Vercel ネイティブ統合が以下を自動注入する:
#   - Neon:  DATABASE_URL / DATABASE_URL_UNPOOLED（プレビューはブランチごとに自動）
#   - Clerk: NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY / CLERK_SECRET_KEY
# そのため Vercel 上では基本的に手動設定は不要。以下はローカル開発用。

# Clerk の公開キー（pk_test_... / pk_live_...）
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Neon の所有者ロール接続文字列（RLS バイパス）。マイグレーション / シード / drizzle-kit 用。
# 本番・プレビューでは Neon 統合が自動注入するため設定不要。
DATABASE_URL=postgresql://OWNER:PASSWORD@HOST/neondb?sslmode=require

# ブラウザが使う authenticated ロール（パスワードレス・JWT）の接続文字列。
# Vercel ビルドでは DATABASE_URL から自動導出される（scripts/vercel-build.mjs）。
# 明示設定するとそちらが優先される。
# DATABASE_AUTHENTICATED_URL=postgresql://authenticated@HOST/neondb?sslmode=require

# シードする所有者の Clerk ユーザー ID（ローカル / 空 DB 用）
SEED_USER_ID=user_xxx

# ---- Firestore → Neon 移行スクリプト用 ----
# サービスアカウント JSON を文字列で渡す（本番 Firestore から読み出す場合）
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ...}
