# --- Database (Prisma Postgres) -----------------------------------------
# IMPORTANT: use the DIRECT PostgreSQL connection string (postgresql://...),
# not the Accelerate (prisma+postgres://) URL. The per-preview schema isolation
# relies on the `?schema=` parameter, which the direct connection supports.
# The schema is appended automatically at runtime/build time; do not hardcode it.
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Optional explicit schema override (CI / migration scripts). When unset the
# schema is derived from the environment:
#   VERCEL_ENV=production -> public
#   VERCEL_ENV=preview    -> preview_<sanitized branch>
#   otherwise             -> public
# DATABASE_SCHEMA=

# --- Clerk (authentication) ---------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# --- Firestore migration (one-time, optional) ---------------------------
# For a real migration set GOOGLE_APPLICATION_CREDENTIALS to a service-account
# JSON path. For the emulator set FIRESTORE_EMULATOR_HOST instead.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# FIREBASE_PROJECT_ID=records-classificater
# UID_MAP_FILE=./uid-map.json   # { "<firebaseUid>": "<clerkUserId>" }
