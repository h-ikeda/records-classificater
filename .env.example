# ---- フロントエンド（Parcel がビルド時に埋め込む / Vercel の環境変数に設定）----

# Clerk の公開キー（pk_test_... / pk_live_...）
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Neon の「authenticated」ロール（JWT ベース・パスワードレス）の接続文字列。
# ブラウザから直接接続するが、Neon RLS が Clerk JWT を検証して行を保護する。
# 例: postgresql://authenticated@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require
DATABASE_AUTHENTICATED_URL=postgresql://authenticated@HOST/neondb?sslmode=require

# ---- サーバー側ツール（マイグレーション / シード / drizzle-kit。所有者権限・コミットしない）----

# Neon の所有者ロール接続文字列（RLS をバイパスできる）。
DATABASE_URL=postgresql://OWNER:PASSWORD@HOST/neondb?sslmode=require

# シードする所有者の Clerk ユーザー ID（プレビュー DB 用）
SEED_USER_ID=user_xxx

# ---- Firestore → Neon 移行スクリプト用 ----

# サービスアカウント JSON を文字列で渡す（本番 Firestore から読み出す場合）
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ...}
